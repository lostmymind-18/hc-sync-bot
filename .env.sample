# Copy this file to .env and fill in real values. Never commit .env.

# OpenAI
OPENAI_API_KEY=
OPENAI_ASSISTANT_ID=
OPENAI_VECTOR_STORE_ID=

# Zendesk / OptiSigns Help Center
ZENDESK_SUBDOMAIN=support.optisigns.com
# Only needed if published articles ever require auth (unlikely for a public
# help center, but kept here in case some sections turn out to be gated):
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

# Chunking strategy (static chunking) — see README for rationale
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=400

# Paths
MARKDOWN_OUTPUT_DIR=data/markdown
STATE_FILE_PATH=data/state.json
